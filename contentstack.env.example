## Contentstack (build-time)
# Region host (default NA):
# CONTENTSTACK_CDN_HOST=cdn.contentstack.io
CONTENTSTACK_CDN_HOST=cdn.contentstack.io
CONTENTSTACK_API_KEY=YOUR_STACK_API_KEY
CONTENTSTACK_DELIVERY_TOKEN=YOUR_DELIVERY_TOKEN
CONTENTSTACK_ENVIRONMENT=YOUR_ENVIRONMENT

## Homepage entry to render
CONTENTSTACK_HOMEPAGE_CONTENT_TYPE_UID=homepage
# Optional: pin a specific entry by UID
# CONTENTSTACK_HOMEPAGE_ENTRY_UID=blt1234567890abcdef

## Field UIDs (edit to match your Content Type)
CONTENTSTACK_FIELD_HERO_TITLE=hero_title
CONTENTSTACK_FIELD_HERO_SUBTITLE=hero_subtitle
CONTENTSTACK_FIELD_TRUSTED_BY_TEXT=trusted_by_text

## Generator inputs/outputs
HOMEPAGE_TEMPLATE=index.template.html
HOMEPAGE_OUTPUT=index.html

